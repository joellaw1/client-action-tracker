# ─── ActionTracker Environment Variables ──────────────────────────────────────
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ─── Google Sheets (Data Layer) ───────────────────────────────────────────────
# Create a Google Sheet under j@joelcohenlegal.com and paste its ID here
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# ─── Google Cloud Project (owned by j@joelcohenlegal.com) ────────────────────
# Create at: https://console.cloud.google.com (logged in as j@joelcohenlegal.com)
# Enable APIs: Gmail API, Google Sheets API
# OAuth consent screen: External, with Paradox Principals email as test user
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# ─── Gmail OAuth Token ───────────────────────────────────────────────────────
# During auth-setup, sign in with your PARADOX PRINCIPALS Google account
# (the inbox you want to scan). The token grants read-only Gmail access.
# The Cloud project lives under joelcohenlegal, but the token is for Paradox.
GOOGLE_REFRESH_TOKEN=your_refresh_token

# ─── Gemini API (Email Scanner) ───────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/apikey (as j@joelcohenlegal.com)
GEMINI_API_KEY=your_gemini_api_key

# ─── Scanner Settings ─────────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=30
MIN_CONFIDENCE_THRESHOLD=0.75
ENABLE_PROACTIVE_TRIGGERS=true

# ─── Firm Configuration ───────────────────────────────────────────────────────
# List ALL attorney emails whose sent mail should be scanned for commitments
FIRM_ATTORNEY_EMAILS=joel@paradoxprincipals.com,partner@paradoxprincipals.com

# ─── App Settings ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# ─── Clio Integration (Optional) ─────────────────────────────────────────────
# CLIO_CLIENT_ID=
# CLIO_CLIENT_SECRET=
# CLIO_REDIRECT_URI=http://localhost:3000/api/auth/callback/clio
